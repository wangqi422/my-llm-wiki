.obsidian/workspace-mobile.json

# CodeBuddy 本地数据
.codebuddy/

# Temp files
_temp_*/
*.tmp
~$*
.obsidian-skills-temp/
.claude/

# Generated card screenshots (可从 HTML 重新生成)
